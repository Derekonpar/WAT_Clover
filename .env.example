# Copy to .env (DO NOT COMMIT)
CLOVER_API_TOKEN=your_clover_api_token
CLOVER_MERCHANT_ID=F94ACDTMC3C51
# Optional (default shown)
CLOVER_BASE_URL=https://api.clover.com
# Dashboard: beer sales/inventory category (default Beer)
CLOVER_SALES_CATEGORY=Beer
# Liquor tab: comma-separated Clover categories (default Liquor,Wine,Cocktail)
CLOVER_LIQUOR_CATEGORIES=Liquor,Wine,Cocktail
# Cache API results (hours) — same date range won't hit Clover again until Refresh
CLOVER_CACHE_TTL_HOURS=24
# Pause between paginated Clover requests (milliseconds)
CLOVER_REQUEST_DELAY_MS=300

# Beer order emails (Confirm send orders uses Gmail below)
# Liquor orders use Provi product IDs — no email (see liquor_provi_product in Supabase).
# Provi must be on Wild Axe when building liquor carts (not On Par Entertainment).
PROVI_LOCATION_NAME=Wild Axe
PROVI_RETAILER_ID=403032
PROVI_OHLQ_ACCOUNT_NUMBER=9609977
# Vercel only — run: python3 scripts/provi/export_vercel_env.py (after setup_session.py)
# PROVI_COOKIES_JSON=[{"name":"_tiz_session","value":"..."},{"name":"XSRF-TOKEN","value":"..."},{"name":"user.id","value":"..."}]
BONBRIGHT_ORDER_EMAIL=avogt@bonbright.com
HEIDELBERG_ORDER_EMAIL=wes.feldmeyer@heidelbergdistributing.com
YELLOW_SPRINGS_ORDER_EMAIL=shawn@yellowspringsbrewery.com
ORDER_FALLBACK_EMAIL=
GMAIL_SENDER=wildaxethrowing@gmail.com
GMAIL_APP_PASSWORD=

# Supabase — weekly usage history for 6-week average par
SUPABASE_URL=
SUPABASE_PROJECT_ID=
# Publishable key works for local server/scripts after RUN_ALL_IN_SQL_EDITOR.sql (RLS policies)
SUPABASE_PUBLISHABLE_KEY=
# Optional: service_role bypasses RLS (server-only; never commit or expose to browser)
SUPABASE_SERVICE_ROLE_KEY=
